DEV_DEBUG=True
PROD_DEBUG=False
DEV_SECRET_KEY=change-me-in-production
PROD_SECRET_KEY=change-me-in-production

# Geliştirme site/API
DEV_SITE_URL=http://localhost:43210
DEV_ALLOWED_HOSTS=localhost,127.0.0.1
DEV_CORS_ALLOWED_ORIGINS=http://localhost:43210,http://127.0.0.1:43210

# Üretim site (temasotoyolyardim.com)
PROD_SITE_URL=https://temasotoyolyardim.com
PROD_ALLOWED_HOSTS=temasotoyolyardim.com,www.temasotoyolyardim.com
PROD_CORS_ALLOWED_ORIGINS=https://temasotoyolyardim.com,https://www.temasotoyolyardim.com
PROD_MAX_UPLOAD_MB=250

# Uygulama portları
DEV_PORT=23658
PROD_PORT=8000
FRONTEND_DEV_PORT=43210

# Geliştirme veritabanı (config.settings.dev)
# Sunucu: DJANGO_SETTINGS_MODULE=config.settings.prod (wsgi/asgi varsayılanı)
# DJANGO_SETTINGS_MODULE=config.settings.dev

# Geliştirme veritabanı (config.settings.dev)
DEV_DB_NAME=tow_truck_temas
DEV_DB_USER=root
DEV_DB_PASSWORD=
DEV_DB_HOST=127.0.0.1
DEV_DB_PORT=3306

# Üretim veritabanı (config.settings.prod — sunucuda manage_prod.py kullanın)
# systemd EnvironmentFile: satır sonu # yorumu KULLANMAYIN (değere karışır).
DB_NAME=tow_truck_temas
DB_USER=tow_truck
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306

# Astro rebuild — admin kaydı sonrası frontend/dist yenilenir (SSG)
ASTRO_REBUILD_LOCAL=false
ASTRO_REBUILD_WEBHOOK_URL=http://127.0.0.1:9876/rebuild
DEV_ASTRO_REBUILD_WEBHOOK_SECRET=dev-webhook-secret-change-in-prod
PROD_ASTRO_REBUILD_WEBHOOK_SECRET=
ASTRO_BUILD_SCRIPT=build:prod
FRONTEND_DIR=../frontend

# Groq çeviri (admin → Groq ile çevir)
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_RETRIES=3
# GROQ_BATCH_PAUSE_SECONDS=1

# Ziyaretçi analitiği (analytics uygulaması)
VISITOR_GEO_LOOKUP=true
# VISITOR_GEO_TIMEOUT=2
# VISITOR_GEO_API_URL=http://ip-api.com/json/{ip}?fields=status,message,country,countryCode,region,regionName,city,zip,lat,lon,timezone,isp,org,query
