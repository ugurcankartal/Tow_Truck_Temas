---
import { localePath, type LanguageInfo, type Locale } from '@/i18n';

interface Props {
  languages: LanguageInfo[];
  locale: Locale;
  defaultLocale: Locale;
  variant?: 'desktop' | 'mobile';
}

const { languages, locale, defaultLocale, variant = 'desktop' } = Astro.props;

const activeLanguages = languages
  .filter((l) => l.is_active)
  .sort((a, b) => a.sort_order - b.sort_order || a.code.localeCompare(b.code));

if (activeLanguages.length <= 1) {
  return null;
}

function flagSrc(lang: LanguageInfo): string {
  if (lang.flag_url) return lang.flag_url;
  const iso = lang.code === 'en' ? 'gb' : lang.code.split('-')[0].toLowerCase();
  return `https://flagcdn.com/24x18/${iso}.png`;
}

const options = activeLanguages.map((lang) => ({
  code: lang.code,
  label: lang.name_native,
  href: localePath(lang.code, defaultLocale),
  flag: flagSrc(lang),
  selected: lang.code === locale,
}));

const current = options.find((o) => o.selected) ?? options[0];
const isMobile = variant === 'mobile';
---

<div
  class:list={['lang-picker', isMobile && 'lang-picker--mobile']}
  data-lang-picker
>
  <button
    type="button"
    class="lang-picker__trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Dil seçimi"
  >
    <span class="lang-picker__flag-wrap" aria-hidden="true">
      <img
        src={current.flag}
        alt=""
        class="lang-picker__flag"
        width="24"
        height="18"
        loading="lazy"
        decoding="async"
      />
    </span>
    <span class="lang-picker__text">
      <span class="lang-picker__name">{current.label}</span>
      <span class="lang-picker__code">{current.code.toUpperCase()}</span>
    </span>
    <svg
      class="lang-picker__chevron"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.94a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z"
        clip-rule="evenodd"
      />
    </svg>
  </button>

  <ul class="lang-picker__menu" role="listbox" hidden>
    {
      options.map((opt) => (
        <li role="presentation">
          <a
            href={opt.href}
            class:list={['lang-picker__option', opt.selected && 'lang-picker__option--active']}
            role="option"
            aria-selected={opt.selected}
            hreflang={opt.code}
            lang={opt.code}
          >
            <img
              src={opt.flag}
              alt=""
              class="lang-picker__flag"
              width="24"
              height="18"
              loading="lazy"
              decoding="async"
            />
            <span class="lang-picker__option-label">{opt.label}</span>
            <span class="lang-picker__option-code">{opt.code.toUpperCase()}</span>
            {opt.selected && (
              <svg class="lang-picker__check" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M16.704 5.29a1 1 0 010 1.42l-7.25 7.25a1 1 0 01-1.42 0l-3.25-3.25a1 1 0 111.42-1.42l2.54 2.54 6.54-6.54a1 1 0 011.42 0z"
                  clip-rule="evenodd"
                />
              </svg>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .lang-picker {
    position: relative;
  }

  .lang-picker__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.5rem;
    padding: 0.35rem 0.65rem 0.35rem 0.45rem;
    border: 1px solid rgb(226 232 240);
    border-radius: 9999px;
    background: rgb(255 255 255);
    box-shadow: 0 1px 2px rgb(15 23 42 / 0.04);
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }

  .lang-picker__trigger:hover {
    border-color: rgb(252 211 77);
    box-shadow: 0 2px 8px rgb(245 158 11 / 0.12);
  }

  .lang-picker__trigger:focus-visible {
    outline: none;
    border-color: rgb(251 191 36);
    box-shadow: 0 0 0 3px rgb(251 191 36 / 0.25);
  }

  .lang-picker[data-open='true'] .lang-picker__trigger {
    border-color: rgb(251 191 36);
    box-shadow: 0 0 0 3px rgb(251 191 36 / 0.15);
  }

  .lang-picker__flag-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    overflow: hidden;
    background: rgb(248 250 252);
    box-shadow: inset 0 0 0 1px rgb(226 232 240);
  }

  .lang-picker__flag {
    display: block;
    width: 1.25rem;
    height: auto;
    object-fit: cover;
    border-radius: 2px;
  }

  .lang-picker__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
    min-width: 0;
  }

  .lang-picker__name {
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgb(51 65 85);
    max-width: 5.5rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lang-picker__code {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgb(217 119 6);
  }

  .lang-picker__chevron {
    width: 1rem;
    height: 1rem;
    color: rgb(148 163 184);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .lang-picker[data-open='true'] .lang-picker__chevron {
    transform: rotate(180deg);
    color: rgb(217 119 6);
  }

  .lang-picker__menu {
    position: absolute;
    top: calc(100% + 0.375rem);
    right: 0;
    z-index: 60;
    min-width: 11rem;
    margin: 0;
    padding: 0.35rem;
    list-style: none;
    border: 1px solid rgb(226 232 240);
    border-radius: 0.875rem;
    background: rgb(255 255 255);
    box-shadow: 0 12px 32px rgb(15 23 42 / 0.12);
  }

  .lang-picker__option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: rgb(51 65 85);
    transition: background-color 0.15s ease;
  }

  .lang-picker__option:hover {
    background: rgb(255 251 235);
    color: rgb(180 83 9);
  }

  .lang-picker__option--active {
    background: rgb(254 243 199);
    color: rgb(146 64 14);
  }

  .lang-picker__option-label {
    flex: 1;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .lang-picker__option-code {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgb(148 163 184);
  }

  .lang-picker__option--active .lang-picker__option-code {
    color: rgb(217 119 6);
  }

  .lang-picker__check {
    width: 1rem;
    height: 1rem;
    color: rgb(217 119 6);
    flex-shrink: 0;
  }

  .lang-picker--mobile {
    width: 100%;
  }

  .lang-picker--mobile .lang-picker__trigger {
    width: 100%;
    justify-content: flex-start;
    border-radius: 0.75rem;
    padding: 0.625rem 0.75rem;
  }

  .lang-picker--mobile .lang-picker__name {
    max-width: none;
    font-size: 0.875rem;
  }

  .lang-picker--mobile .lang-picker__code {
    font-size: 0.6875rem;
  }

  .lang-picker--mobile .lang-picker__menu {
    position: static;
    width: 100%;
    margin-top: 0.5rem;
    box-shadow: none;
    border-radius: 0.75rem;
  }

  .lang-picker--mobile[data-open='true'] .lang-picker__menu {
    display: block;
  }
</style>
