---
import type { BusinessView, HeroIntro, HeroSlide } from '@/lib/site-settings';
import { repairIcons } from '@/data/repair-icons';
import { getUi, type UiMessages } from '@/i18n';

interface Props {
  business: BusinessView;
  slides: HeroSlide[];
  heroIntro: HeroIntro;
  ui: UiMessages;
}

const { business, slides, heroIntro, ui } = Astro.props;
---

<section
  id="hero"
  class="hero-section relative flex w-screen flex-col overflow-hidden bg-white pt-[var(--site-header-total)] max-md:h-auto md:h-screen md:min-h-[100dvh]"
  aria-label={ui.hero.aria}
>
  <!-- Slider — mobilde daha yüksek, navbar altında -->
  <div
    class="hero-slider relative w-screen shrink-0 overflow-hidden shadow-2xl shadow-slate-900/10 max-md:h-[clamp(22rem,62dvh,34rem)] md:min-h-0 md:flex-1"
    data-slider
    data-interval="5000"
  >
    {slides.map((slide, i) => (
      <div
        class="hero-slide absolute inset-0"
        data-slide={i}
        data-active={i === 0 ? 'true' : 'false'}
        style={i === 0 ? 'z-index:2;opacity:1;transform:translateX(0) scale(1)' : 'z-index:0;opacity:0;transform:translateX(5%) scale(1.02)'}
      >
        <img
          src={slide.image}
          alt={slide.alt}
          class="h-full w-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          width="1600"
          height="900"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-slate-900/20 to-transparent" aria-hidden="true" />
        <div class="hero-caption absolute bottom-0 left-0 p-4 sm:p-6 lg:p-10">
          <p class="mb-1 text-xs font-semibold tracking-widest text-amber-400 uppercase sm:text-sm">{slide.subtitle}</p>
          <p class="font-display text-2xl font-bold text-white sm:text-3xl lg:text-5xl">{slide.title}</p>
        </div>
      </div>
    ))}

    <div class="absolute top-0 left-0 z-10 h-1 w-full bg-white/20" aria-hidden="true">
      <div class="hero-progress h-full origin-left bg-amber-400" style="transform:scaleX(0)"></div>
    </div>

    <div class="absolute bottom-3 left-1/2 z-10 flex max-w-[92vw] -translate-x-1/2 flex-wrap justify-center gap-1.5 sm:bottom-4 sm:gap-2" role="tablist" aria-label={ui.hero.slideSelect}>
      {slides.map((_, i) => (
        <button
          type="button"
          class="hero-dot"
          data-dot={i}
          data-active={i === 0 ? 'true' : 'false'}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`${ui.hero.slideN} ${i + 1}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 sm:h-5 sm:w-5" aria-hidden="true">
            {repairIcons[i % repairIcons.length].map((d) => (
              <path stroke-linecap="round" stroke-linejoin="round" d={d} />
            ))}
          </svg>
        </button>
      ))}
    </div>
  </div>

  <!-- Intro -->
  <div class="mx-auto w-full max-w-6xl shrink-0 px-4 py-4 sm:px-6 sm:py-5 lg:px-10 md:mt-4 md:pb-4">
    <div class="grid gap-3 sm:gap-4 lg:grid-cols-2 lg:gap-8">
      <div class="animate-fade-up">
        <span class="inline-flex items-center gap-2 rounded-full bg-amber-50 px-3 py-1 text-[10px] font-semibold tracking-wide text-amber-700 uppercase sm:text-xs">
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-500" aria-hidden="true"></span>
          {heroIntro.badge}
        </span>
        <h1
          class="mt-2 font-display text-xl font-extrabold tracking-tight text-slate-900 sm:text-2xl lg:text-3xl"
          set:html={heroIntro.title_html}
        />
      </div>
      <div class="animate-fade-up-delay flex flex-col justify-center gap-3 sm:gap-4">
        <div class="hero-intro-body" set:html={heroIntro.body_html} />
        <div class="flex flex-wrap gap-3 pt-0 sm:pt-1">
          <a
            href={business.phoneHref}
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-slate-900 px-6 py-3.5 text-sm font-semibold text-white transition-all hover:bg-slate-800 hover:shadow-lg sm:w-auto sm:py-3"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c1.067 2.17 2.767 3.87 4.937 4.937l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-7.456 0-13.5-6.044-13.5-13.5V4.5A1.5 1.5 0 012 3.5z" clip-rule="evenodd" />
            </svg>
            {ui.hero.callNow}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-slider {
    cursor: grab;
    touch-action: pan-y pinch-zoom;
    user-select: none;
    -webkit-user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .hero-slider.is-dragging {
    cursor: grabbing;
  }
  .hero-slide {
    transition:
      opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
    pointer-events: none;
  }
  .hero-slide[data-active='true'] {
    pointer-events: auto;
  }
  .hero-caption {
    transition: opacity 0.6s ease 0.2s, transform 0.6s ease 0.2s;
    opacity: 0;
    transform: translateY(24px);
  }
  .hero-slide[data-active='true'] .hero-caption {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.125rem;
    border: none;
    background: transparent;
    color: rgb(255 255 255 / 0.5);
    cursor: pointer;
    transition: transform 0.3s ease, color 0.3s ease, opacity 0.3s ease;
  }
  .hero-dot:hover {
    color: rgb(255 255 255 / 0.9);
  }
  .hero-dot[data-active='true'] {
    color: rgb(251 191 36);
    transform: scale(1.2);
  }
  .hero-intro-body :global(p) {
    font-size: 0.875rem;
    line-height: 1.625;
    color: rgb(71 85 105);
  }
  @media (min-width: 1024px) {
    .hero-intro-body :global(p) {
      font-size: 1rem;
    }
  }
  .hero-intro-body :global(p + p) {
    display: none;
    color: rgb(100 116 139);
  }
  @media (min-width: 640px) {
    .hero-intro-body :global(p + p) {
      display: block;
    }
  }
  .hero-intro-body :global(strong) {
    font-weight: 600;
    color: rgb(15 23 42);
  }
  .hero-intro-body :global(a) {
    color: rgb(217 119 6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

<script>
  function initHeroSlider() {
    const root = document.querySelector('[data-slider]') as HTMLElement;
    if (!root || root.dataset.sliderInit === 'true') return;
    root.dataset.sliderInit = 'true';

    const slides = Array.from(root.querySelectorAll('[data-slide]')) as HTMLElement[];
    const dots = Array.from(root.querySelectorAll('[data-dot]')) as HTMLButtonElement[];
    const progress = root.querySelector('.hero-progress') as HTMLElement;
    const interval = Number(root.dataset.interval) || 5000;
    const swipeThreshold = Math.min(80, root.clientWidth * 0.12);

    let active = 0;
    let direction: 'next' | 'prev' = 'next';
    let timer: ReturnType<typeof setInterval>;
    let isDragging = false;
    let dragStartX = 0;
    let dragDeltaX = 0;

    function normalizeIndex(index: number) {
      return ((index % slides.length) + slides.length) % slides.length;
    }

    function setDotsState() {
      dots.forEach((dot, i) => {
        const isActive = i === active;
        dot.dataset.active = String(isActive);
        dot.setAttribute('aria-selected', String(isActive));
      });
    }

    function cancelTransitions() {
      slides.forEach((slide) => {
        slide.style.transition = 'none';
      });
    }

    function applySlideStates(prev: number, enableTransition = true) {
      slides.forEach((slide, i) => {
        const isActive = i === active;
        const isPrev = i === prev;

        slide.dataset.active = String(isActive);
        slide.style.zIndex = isActive ? '2' : isPrev ? '1' : '0';
        slide.style.transition = enableTransition ? '' : 'none';

        if (isActive) {
          slide.style.opacity = '1';
          slide.style.transform = 'translateX(0) scale(1)';
          slide.classList.add('hero-slide-active');
        } else {
          slide.classList.remove('hero-slide-active');
          slide.style.opacity = '0';
          slide.style.transform = direction === 'next'
            ? 'translateX(-5%) scale(1.02)'
            : 'translateX(5%) scale(1.02)';
        }
      });
      setDotsState();
    }

    function restartProgress() {
      progress.classList.remove('hero-progress-bar');
      void progress.offsetWidth;
      progress.classList.add('hero-progress-bar');
    }

    function goToSlide(targetIndex: number) {
      const nextActive = normalizeIndex(targetIndex);
      if (nextActive === active) return;

      cancelTransitions();

      const forward = (nextActive - active + slides.length) % slides.length;
      const backward = (active - nextActive + slides.length) % slides.length;
      direction = forward <= backward ? 'next' : 'prev';

      const prev = active;
      active = nextActive;
      applySlideStates(prev, true);
      restartProgress();
    }

    function next() { goToSlide(active + 1); }
    function prev() { goToSlide(active - 1); }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(next, interval);
    }

    function stopAuto() {
      clearInterval(timer);
    }

    function resetDragSlides() {
      slides.forEach((slide, i) => {
        if (i !== active) {
          slide.style.opacity = '0';
          slide.style.zIndex = '0';
          slide.style.transform = direction === 'next'
            ? 'translateX(5%) scale(1.02)'
            : 'translateX(-5%) scale(1.02)';
        }
      });
    }

    function onPointerDown(e: PointerEvent) {
      if ((e.target as Element).closest('.hero-dot')) return;
      if (e.button !== 0) return;

      cancelTransitions();
      isDragging = true;
      dragStartX = e.clientX;
      dragDeltaX = 0;
      root.classList.add('is-dragging');
      root.setPointerCapture(e.pointerId);
      stopAuto();

      const activeSlide = slides[active];
      if (activeSlide) {
        activeSlide.style.zIndex = '2';
        activeSlide.style.opacity = '1';
        activeSlide.style.transform = 'translateX(0) scale(1)';
      }
    }

    function onPointerMove(e: PointerEvent) {
      if (!isDragging) return;

      dragDeltaX = e.clientX - dragStartX;
      const width = root.clientWidth || 1;
      const activeSlide = slides[active];
      if (!activeSlide) return;

      if (Math.abs(dragDeltaX) > 6) {
        e.preventDefault();
      }

      activeSlide.style.transform = `translateX(${dragDeltaX}px) scale(1)`;

      const adjIndex = dragDeltaX < 0
        ? normalizeIndex(active + 1)
        : normalizeIndex(active - 1);
      const adjSlide = slides[adjIndex];
      if (!adjSlide || dragDeltaX === 0) return;

      const baseX = dragDeltaX < 0 ? width : -width;
      adjSlide.style.transition = 'none';
      adjSlide.style.zIndex = '1';
      adjSlide.style.opacity = '1';
      adjSlide.style.transform = `translateX(${baseX + dragDeltaX}px) scale(1)`;
    }

    function onPointerEnd(e: PointerEvent) {
      if (!isDragging) return;

      isDragging = false;
      root.classList.remove('is-dragging');

      if (root.hasPointerCapture(e.pointerId)) {
        root.releasePointerCapture(e.pointerId);
      }

      const activeSlide = slides[active];
      const delta = dragDeltaX;
      dragDeltaX = 0;

      if (Math.abs(delta) >= swipeThreshold) {
        goToSlide(active + (delta < 0 ? 1 : -1));
      } else if (activeSlide) {
        activeSlide.style.transition = '';
        activeSlide.style.transform = 'translateX(0) scale(1)';
        resetDragSlides();
      }

      startAuto();
    }

    root.addEventListener('pointerdown', onPointerDown);
    root.addEventListener('pointermove', onPointerMove);
    root.addEventListener('pointerup', onPointerEnd);
    root.addEventListener('pointercancel', onPointerEnd);

    dots.forEach((dot) => {
      const goToDot = (e: Event) => {
        e.preventDefault();
        e.stopPropagation();
        const i = Number((dot as HTMLButtonElement).dataset.dot);
        if (!Number.isNaN(i)) {
          goToSlide(i);
          startAuto();
        }
      };
      dot.addEventListener('click', goToDot);
      dot.addEventListener('pointerdown', (e) => e.stopPropagation());
    });

    slides[0]?.classList.add('hero-slide-active');
    restartProgress();
    startAuto();
  }

  initHeroSlider();
  document.addEventListener('astro:page-load', initHeroSlider);
</script>
