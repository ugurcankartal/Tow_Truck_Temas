---
import BrandLogo from '@/components/BrandLogo.astro';
import type { BusinessView } from '@/lib/site-settings';
import { renderFooterCopyright } from '@/lib/site-settings';
import type { UiMessages } from '@/i18n';

interface Props {
  business: BusinessView;
  ui: UiMessages;
}

const { business, ui } = Astro.props;
const fullAddress = `${business.address.street}, ${business.address.district}, ${business.address.city}`;
const copyrightText = renderFooterCopyright(business.footerCopyright, business.legalName);
---

<footer
  id="footer"
  class="flex min-h-[100dvh] w-screen flex-col justify-between bg-slate-950 text-slate-300"
  role="contentinfo"
>
  <div class="mx-auto w-full max-w-7xl flex-1 px-6 py-16 lg:px-10 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="#hero" class="group flex items-center gap-3">
          <BrandLogo business={business} variant="footer" />
          <div>
            <p class="font-display text-lg font-bold text-white">{business.name}</p>
            <p class="text-xs tracking-widest text-amber-500 uppercase">{business.tagline}</p>
          </div>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-slate-400">
          {ui.footer.blurb}
        </p>
      </div>

      <!-- Services areas -->
      <div>
        <h2 class="mb-4 font-display text-sm font-semibold tracking-widest text-white uppercase">{ui.footer.areasTitle}</h2>
        <ul class="flex flex-col gap-2" role="list">
          {business.areaServed.slice(0, 6).map((area) => (
            <li class="text-sm text-slate-400">{area}</li>
          ))}
        </ul>
      </div>

      <!-- NAP -->
      <div>
        <h2 class="mb-4 font-display text-sm font-semibold tracking-widest text-white uppercase">{ui.footer.contactTitle}</h2>
        <address class="not-italic">
          <ul class="flex flex-col gap-3 text-sm" role="list">
            <li>
              <span class="block text-xs text-slate-500 uppercase">{ui.footer.phone}</span>
              <a href={business.phoneHref} class="font-semibold text-white hover:text-amber-400">{business.phone}</a>
            </li>
            <li>
              <span class="block text-xs text-slate-500 uppercase">{ui.footer.email}</span>
              <a href={`mailto:${business.email}`} class="text-slate-300 hover:text-amber-400">{business.email}</a>
            </li>
            <li>
              <span class="block text-xs text-slate-500 uppercase">{ui.footer.address}</span>
              <span class="text-slate-300">{fullAddress}</span>
            </li>
            <li>
              <span class="block text-xs text-slate-500 uppercase">{ui.footer.hours}</span>
              <span class="text-slate-300">{business.openingHours}</span>
            </li>
          </ul>
        </address>
      </div>
    </div>

    <!-- CTA strip -->
    <div class="mt-16 flex flex-col items-center justify-between gap-6 rounded-2xl border border-slate-800 bg-slate-900/50 p-8 text-center sm:flex-row sm:text-left">
      <div>
        <p class="font-display text-xl font-bold text-white">{ui.footer.ctaTitle}</p>
        <p class="mt-1 text-sm text-slate-400">{ui.footer.ctaSubtitle}</p>
      </div>
      <a
        href={business.phoneHref}
        class="inline-flex shrink-0 items-center gap-2 rounded-full bg-amber-500 px-8 py-3.5 text-sm font-bold text-white shadow-lg shadow-amber-500/20 transition-all hover:bg-amber-400"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c1.067 2.17 2.767 3.87 4.937 4.937l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-7.456 0-13.5-6.044-13.5-13.5V4.5A1.5 1.5 0 012 3.5z" clip-rule="evenodd" />
        </svg>
        {business.phone}
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-800">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 text-xs text-slate-500 sm:flex-row lg:px-10">
      <p>{copyrightText}</p>
      <div class="flex gap-4">
        <a href={business.social.instagram} rel="noopener noreferrer" target="_blank" class="hover:text-amber-400" aria-label="Instagram">Instagram</a>
        <a href={business.social.facebook} rel="noopener noreferrer" target="_blank" class="hover:text-amber-400" aria-label="Facebook">Facebook</a>
      </div>
    </div>
  </div>
</footer>
