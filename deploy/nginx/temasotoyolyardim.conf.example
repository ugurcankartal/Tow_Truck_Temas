# Nginx — temasotoyolyardim.com
# Statik Astro (frontend/dist) + Gunicorn WSGI (Django REST API / admin / media)
#
# Proje dizini: /home/ubuntu/Tow_Truck_Temas/
#   git clone https://github.com/ugurcankartal/Tow_Truck_Temas.git /home/ubuntu/Tow_Truck_Temas
#
# www-data erişimi için (ilk kurulumda bir kez):
#   sudo chmod 755 /home/ubuntu
#
#   backend/.env  → PROD_SITE_URL, PROD_ALLOWED_HOSTS, PROD_CORS_*, DB_*
#   frontend      → npm run build:prod  →  dist/
#   backend       → python manage.py collectstatic --noinput
#   Gunicorn      → deploy/systemd/temasotoyolyardim-gunicorn.service.example
#
# Kurulum:
#   sudo cp deploy/nginx/temasotoyolyardim.conf.example /etc/nginx/sites-available/temasotoyolyardim
#   sudo ln -sf /etc/nginx/sites-available/temasotoyolyardim /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

upstream django_backend {
    server unix:/run/temasotoyolyardim/gunicorn.sock fail_timeout=0;
}

server {
    listen 443 ssl http2;
    server_name temasotoyolyardim.com www.temasotoyolyardim.com;

    # ssl_certificate     /etc/letsencrypt/live/temasotoyolyardim.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/temasotoyolyardim.com/privkey.pem;

    root /home/ubuntu/Tow_Truck_Temas/frontend/dist;
    index index.html;

    # Admin medya / API yüklemeleri (Django PROD_MAX_UPLOAD_MB ile uyumlu)
    client_max_body_size 250M;
    client_body_timeout 300s;

    location /static/ {
        alias /home/ubuntu/Tow_Truck_Temas/backend/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /api/ {
        proxy_pass http://django_backend;
        proxy_redirect off;

        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /admin/ {
        proxy_pass http://django_backend;
        proxy_redirect off;

        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /media/ {
        proxy_pass http://django_backend;
        proxy_redirect off;

        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /robots.txt {
        try_files $uri @django;
    }

    location = /sitemap.xml {
        try_files $uri @django;
    }

    location @django {
        proxy_pass http://django_backend;
        proxy_redirect off;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    server_name temasotoyolyardim.com www.temasotoyolyardim.com;
    return 301 https://temasotoyolyardim.com$request_uri;
}
